{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage Monitor",
  "version": "0.1.0",
  "identifier": "dev.codex.usage-monitor",
  "build": {
    "beforeDevCommand": "pnpm dev -- --strictPort --port 5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Usage Monitor",
        "width": 1100,
        "height": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
